generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- Enum Types ---

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  DONE
  CANCELED
  NO_SHOW
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

// --- Models ---

model Tenant {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  timezone         String   @default("UTC")
  slotStep         Int      @default(30) // em minutos (slot de agenda)
  plan             String   @default("start") // "start" ou "advanced"
  
  // Configurações do mini site (Nova Estrutura Consolidada)
  website          Json?    // { templateId, content: { brandName, headline, ... }, flags: { showPrices, ... }, style: { primaryColor } }
  
  // Campos Legados (Mantidos para migração conforme Etapa 2 do plano)
  templateId       String   @default("lash-beauty")
  customization    Json?    // { logoUrl, heroTitle, heroSubtitle, galleryUrls[], whatsapp, showPrices }
  websiteConfig    Json?    
  theme            Json?    
  publishedAt      DateTime?
  isPublished      Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  locations        Location[]
  staff            Staff[]
  services         Service[]
  customers        Customer[]
  appointments     Appointment[]
  blocks           Block[]
  users            User[]
  staffServices    StaffService[]

  @@index([slug])
}

model TemplateConfig {
  id              String   @id
  name            String   
  description     String
  category        String   
  primaryColor    String   
  secondaryColor  String   
  accentColor     String?
  fontPrimary     String   @default("Inter")
  fontSecondary   String   @default("Playfair Display")
  borderRadius    String   @default("16px")
  layoutStyle     String   
  
  defaultTitle    String
  defaultSubtitle String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  name      String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  staff     Staff[]
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  status    String @default("ACTIVE")
  
  // Grade de trabalho (JSON) — ex: { mon: {active:true, start:"09:00", end:"18:00", breaks:[{start:"12:00",end:"13:00"}]}, ... }
  workSchedule Json?

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  services     StaffService[]
  appointments Appointment[]
  blocks       Block[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([locationId])
  @@unique([tenantId, name])
}

model Service {
  id           String   @id @default(cuid())
  name         String
  category     String?  // Ex: "Lash", "Sobrancelha"
  duration     Int      // Minutos
  price        Float
  bufferBefore Int      @default(0)
  bufferAfter  Int      @default(0)
  active       Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  imageUrl     String?  // Foto do serviço

  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  staff        StaffService[]
  appointments Appointment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@unique([tenantId, name])
}

// Tabela dinâmica para definir quais profissionais fazem quais serviços
model StaffService {
  staffId   String
  serviceId String
  duration  Int?    // Opcional: sobrescreve a duração padrão do serviço para este profissional
  price     Float? 

  staff     Staff    @relation(fields: [staffId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@id([staffId, serviceId])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   // Prioritário conforme requisitos
  email     String?
  noShows   Int      @default(0)
  tags      String? // Comma separated tags for SQLite

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([phone])
}

model Appointment {
  id          String            @id @default(cuid())
  startTime   DateTime          // UTC conforme requisitos
  endTime     DateTime          // UTC conforme requisitos
  status      String @default("SCHEDULED")
  notes       String?

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id])
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, startTime])
  @@index([staffId, startTime])
  @@index([customerId])
  @@index([status, startTime])
}

model Block {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  reason    String?

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([staffId])
}
